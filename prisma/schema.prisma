generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  MANAGER
  ADMIN
}

enum PropertyStatus {
  DRAFT
  LIVE
  ARCHIVED
}

enum ReservationStatus {
  TENTATIVE
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  OWNER_HOLD
}

enum ReservationSource {
  DIRECT
  AIRBNB
  VRBO
  MANUAL
  OWNER
}

enum PricingPlatform {
  DIRECT
  AIRBNB
  VRBO
}

enum ChargeCategory {
  FEE
  TAX
}

enum ChargeType {
  FIXED
  PERCENT
}

enum ChargeBasis {
  BASE
  BASE_PLUS_FEES
  SUBTOTAL_BEFORE_TAX
}

enum PaymentMethodType {
  STRIPE
  ZELLE
  VENMO
  CASH_APP
}

enum InquiryStatus {
  NEEDS_REPLY
  AWAITING_GUEST
  BOOKED
  CLOSED
}

enum InquiryMessageDirection {
  INBOUND
  OUTBOUND
}

enum InquiryMessageAuthorType {
  GUEST
  OWNER
  ASSISTANT
  SYSTEM
}

enum InquiryDraftStatus {
  DRAFT
  PENDING_OWNER_APPROVAL
  APPROVED
  SENT
}

enum CustomerStatus {
  LEAD
  ACTIVE
  BOOKED
  REPEAT_GUEST
  INACTIVE
  DO_NOT_CONTACT
  VIP
}

enum PlatformLeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  CONVERTED
  UNQUALIFIED
  SUSPICIOUS
  SPAM
  ARCHIVED
}

enum PlatformLeadArtifactType {
  LEAD_BRIEF
  FIRST_RESPONSE_DRAFT
  PROPOSAL_RATIONALE
  PROPOSAL_DRAFT
  ONBOARDING_BRIEF
  ONBOARDING_EMAIL_DRAFT
}

enum PlatformLeadArtifactStatus {
  DRAFT
  NEEDS_APPROVAL
  APPROVED
  SENT
  REJECTED
  SUPERSEDED
}

enum PreviewBuildStatus {
  DRAFT
  READY_FOR_REVIEW
  SHARED_WITH_LEAD
  PROMOTED_TO_SITE
  ARCHIVED
}

enum ContractExecutionStatus {
  NOT_STARTED
  DRAFTED
  SENT
  SIGNED
  COUNTERSIGNED
  VOIDED
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  passwordHash   String?
  fullName       String?
  role           UserRole      @default(OWNER)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  ownerProfiles  Owner[]       @relation("OwnerPrimaryUser")
  memberships    OwnerMember[]
  auditLogs      AuditLog[]
  platformLeadNotes PlatformLeadNote[]
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorEmail  String?
  actorRole   UserRole?
  action      String
  entityType  String
  entityId    String?
  ownerId     String?
  propertyId  String?
  metadata    Json?
  createdAt   DateTime @default(now())
  actorUser   User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@index([entityType, entityId])
  @@index([ownerId, createdAt])
  @@index([propertyId, createdAt])
}

model PlatformLead {
  id                  String             @id @default(cuid())
  status              PlatformLeadStatus @default(NEW)
  fullName            String
  email               String
  phone               String?
  company             String?
  propertyName        String?
  propertyCount       Int?
  propertyLocation    String?
  currentWebsite      String?
  desiredCustomDomain String?
  pms                 String?
  launchTimeline      String?
  goal                String?
  message             String?
  source              String             @default("direct")
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  firstRead           String?
  nextAction          String?
  nextFollowUpAt      DateTime?
  assignedToUserId    String?
  spamReason          String?
  spamReviewedAt      DateTime?
  pricingSetupFeeCents Int?
  pricingMonthlyFeeCents Int?
  pricingCommissionBps Int?
  pricingPaymentProcessingBps Int?
  pricingNotes        String?
  contractStatus      ContractExecutionStatus @default(NOT_STARTED)
  contractSentAt      DateTime?
  contractSignedAt    DateTime?
  contractStorageUrl  String?
  launchChecklist     Json?
  notes               PlatformLeadNote[]
  artifacts           PlatformLeadArtifact[]
  previewBuilds       PreviewBuild[]

  @@index([status, createdAt])
  @@index([email])
  @@index([assignedToUserId, nextFollowUpAt])
}

model PlatformLeadArtifact {
  id             String                     @id @default(cuid())
  platformLeadId String
  type           PlatformLeadArtifactType
  status         PlatformLeadArtifactStatus @default(DRAFT)
  title          String
  body           String
  metadata       Json?
  createdByEmail String?
  approvedByEmail String?
  approvedAt     DateTime?
  sentAt         DateTime?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  platformLead   PlatformLead               @relation(fields: [platformLeadId], references: [id], onDelete: Cascade)

  @@index([platformLeadId, createdAt])
  @@index([type, status, createdAt])
}

model PreviewBuild {
  id             String             @id @default(cuid())
  platformLeadId String
  slug           String             @unique
  status         PreviewBuildStatus @default(DRAFT)
  propertyName   String
  location       String
  sourceUrls     String[]
  heroTitle      String?
  positioning    String?
  sections       Json?
  ownerCallouts  Json?
  sharedAt       DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  platformLead   PlatformLead       @relation(fields: [platformLeadId], references: [id], onDelete: Cascade)

  @@index([platformLeadId, createdAt])
  @@index([status, createdAt])
}

model PlatformLeadNote {
  id             String       @id @default(cuid())
  platformLeadId String
  authorUserId   String?
  authorEmail    String?
  body           String
  createdAt      DateTime     @default(now())
  platformLead   PlatformLead @relation(fields: [platformLeadId], references: [id], onDelete: Cascade)
  authorUser     User?        @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([platformLeadId, createdAt])
  @@index([authorUserId, createdAt])
}

model Owner {
  id             String         @id @default(cuid())
  displayName    String
  supportEmail   String?
  supportPhone   String?
  primaryUserId  String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  primaryUser    User?          @relation("OwnerPrimaryUser", fields: [primaryUserId], references: [id])
  properties     Property[]
  members        OwnerMember[]
  customers      Customer[]
}

model OwnerMember {
  id         String    @id @default(cuid())
  ownerId     String
  userId      String
  title       String?
  createdAt   DateTime  @default(now())
  owner       Owner     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ownerId, userId])
}

model Property {
  id                        String             @id @default(cuid())
  ownerId                   String
  slug                      String             @unique
  name                      String
  status                    PropertyStatus     @default(DRAFT)
  publicDomain              String?
  inquiryEmail              String?
  inquiryPhone              String?
  aiReplyInstructions       String?
  timezone                  String             @default("America/New_York")
  currency                  String             @default("USD")
  minimumStayNights         Int?
  checkInTime               String?
  checkOutTime              String?
  inquiryEnabled            Boolean            @default(true)
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt
  owner                     Owner              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  content                   PropertyContent?
  reservations              Reservation[]
  pricingRules              PricingRule[]
  paymentMethods            PaymentMethod[]
  paymentSettings           PaymentSetting?
  inquiries                 Inquiry[]
  primaryCustomers          Customer[]           @relation("CustomerPrimaryProperty")
}

model Customer {
  id                     String         @id @default(cuid())
  ownerId                String
  primaryPropertyId      String?
  fullName               String
  email                  String
  phone                  String?
  locationLabel          String?
  timezone               String?
  preferredContactMethod String?
  status                 CustomerStatus @default(LEAD)
  notes                  String?
  preferencesSummary     String?
  householdSummary       String?
  specialOccasions       String?
  conciergeInterests     String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  owner                  Owner          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  primaryProperty        Property?      @relation("CustomerPrimaryProperty", fields: [primaryPropertyId], references: [id], onDelete: SetNull)
  inquiries              Inquiry[]
  reservations           Reservation[]

  @@unique([ownerId, email])
  @@index([ownerId, createdAt])
  @@index([ownerId, status])
}

model PropertyContent {
  id                    String    @id @default(cuid())
  propertyId            String    @unique
  headline              String?
  subheadline           String?
  locationSummary       String?
  aboutCopy             String?
  fishingCopy           String?
  locationCopy          String?
  faqEnabled            Boolean   @default(true)
  experiencePageEnabled Boolean   @default(true)
  updatedAt             DateTime  @updatedAt
  property              Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Reservation {
  id                String              @id @default(cuid())
  propertyId        String
  customerId        String?
  externalReference String?
  status            ReservationStatus   @default(TENTATIVE)
  source            ReservationSource   @default(MANUAL)
  bookingType       String?
  bookedDate        DateTime?
  guestName         String?
  guestEmail        String?
  guestPhone        String?
  checkIn           DateTime
  checkOut          DateTime
  nights            Int
  totalAmount       Decimal?            @db.Decimal(10, 2)
  currency          String              @default("USD")
  isOwnerWeek       Boolean             @default(false)
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  property          Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  customer          Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([propertyId, checkIn, checkOut])
  @@index([customerId])
}

model PricingRule {
  id                String            @id @default(cuid())
  propertyId        String
  platform          PricingPlatform
  startDate         DateTime
  endDate           DateTime
  nightlyRate       Decimal           @db.Decimal(10, 2)
  minimumStayNights Int?
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  property          Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  charges           PricingCharge[]

  @@index([propertyId, platform, startDate, endDate])
}

model PricingCharge {
  id            String         @id @default(cuid())
  pricingRuleId String
  label         String
  category      ChargeCategory
  chargeType    ChargeType
  value         Decimal        @db.Decimal(10, 4)
  basis         ChargeBasis    @default(BASE)
  perNight      Boolean        @default(false)
  pricingRule   PricingRule    @relation(fields: [pricingRuleId], references: [id], onDelete: Cascade)
}

model PaymentMethod {
  id            String             @id @default(cuid())
  propertyId     String
  method         PaymentMethodType
  enabled        Boolean            @default(false)
  isPrimary      Boolean            @default(false)
  displayOrder   Int                @default(0)
  instructions   String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  property       Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, method])
}

model PaymentSetting {
  id                               String    @id @default(cuid())
  propertyId                        String    @unique
  depositPercentage                 Int       @default(0)
  finalPaymentDueDays               Int       @default(30)
  allowManualFallbacks              Boolean   @default(true)
  requireOwnerApprovalBeforePayment Boolean   @default(true)
  createdAt                         DateTime  @default(now())
  updatedAt                         DateTime  @updatedAt
  property                          Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Inquiry {
  id           String        @id @default(cuid())
  propertyId   String
  customerId   String?
  fullName     String
  email        String
  phone        String?
  checkIn      DateTime?
  checkOut     DateTime?
  message      String?
  status       InquiryStatus @default(NEEDS_REPLY)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  customer     Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  messages     InquiryMessage[]
  drafts       InquiryReplyDraft[]

  @@index([propertyId, status, createdAt])
  @@index([customerId])
}

model InquiryMessage {
  id             String                  @id @default(cuid())
  inquiryId      String
  direction      InquiryMessageDirection
  authorType     InquiryMessageAuthorType
  subject        String?
  body           String
  emailMessageId String?
  sentAt         DateTime?
  receivedAt     DateTime?
  createdAt      DateTime                @default(now())
  inquiry        Inquiry                 @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([inquiryId, createdAt])
}

model InquiryReplyDraft {
  id             String            @id @default(cuid())
  inquiryId       String
  subject         String?
  body            String
  status          InquiryDraftStatus @default(DRAFT)
  createdByType   InquiryMessageAuthorType @default(ASSISTANT)
  approvedAt      DateTime?
  sentAt          DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  inquiry         Inquiry           @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([inquiryId, status, updatedAt])
}
