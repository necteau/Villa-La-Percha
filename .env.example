# Public site
NEXT_PUBLIC_SITE_URL=https://directstay.app

# Email
RESEND_API_KEY=
RESEND_FROM_EMAIL=
INQUIRY_NOTIFICATION_EMAIL=
# Recommended production value after Cloudflare inbound routing is live:
# INQUIRY_REPLY_TO_EMAIL=villalapercha@directstay.app
INQUIRY_REPLY_TO_EMAIL=
INQUIRY_WEBHOOK_SECRET=

# Owner portal auth (Supabase Auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Comma-separated allowlist for owner portal access
OWNER_PORTAL_ALLOWED_EMAILS=owner@directstay.app
# Backward-compatible single-email fallback if allowlist is omitted
OWNER_PORTAL_EMAIL=owner@directstay.app

# Database
# Runtime/app connection (use pooled connection for hosted environments)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/directstay?schema=public
# Prisma migrations / direct admin connection
DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/directstay?schema=public

# Internal DirectStay AI draft upgrade worker
# Shared secret used by the Mac Studio worker to read pending template drafts and write upgraded AI drafts.
DIRECTSTAY_INTERNAL_API_SECRET=
DIRECTSTAY_AI_DEFAULT_MODEL=openai-codex/gpt-5.5
DIRECTSTAY_AI_UPGRADE_MAX_ATTEMPTS=5

# Mac Studio worker-only values
DIRECTSTAY_SITE_URL=https://directstay.app
DIRECTSTAY_AI_WORKER_LIMIT=5
# Command that reads a JSON draft job from stdin and returns {"subject":"...","body":"...","modelUsed":"..."}
DIRECTSTAY_AI_DRAFT_COMMAND=./scripts/directstay-ai-draft-generator-openclaw.mjs
DIRECTSTAY_AI_DRAFT_GENERATOR_ENDPOINT=
