# Public site
NEXT_PUBLIC_SITE_URL=https://directstay.app

# Email
RESEND_API_KEY=

# Owner portal auth (temporary until full auth provider is added)
OWNER_PORTAL_EMAIL=owner@directstay.app
OWNER_PORTAL_PASSWORD=replace-with-a-strong-password
OWNER_PORTAL_SESSION_SECRET=replace-with-a-long-random-session-secret

# Database
# Runtime/app connection (use pooled connection for hosted environments)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/directstay?schema=public
# Prisma migrations / direct admin connection
DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/directstay?schema=public
