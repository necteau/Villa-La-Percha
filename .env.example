# Public site
NEXT_PUBLIC_SITE_URL=https://directstay.app

# Email
RESEND_API_KEY=
RESEND_FROM_EMAIL=
INQUIRY_NOTIFICATION_EMAIL=
INQUIRY_REPLY_TO_EMAIL=
INQUIRY_WEBHOOK_SECRET=

# Owner portal auth (Supabase Auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Comma-separated allowlist for owner portal access
OWNER_PORTAL_ALLOWED_EMAILS=owner@directstay.app
# Backward-compatible single-email fallback if allowlist is omitted
OWNER_PORTAL_EMAIL=owner@directstay.app

# Database
# Runtime/app connection (use pooled connection for hosted environments)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/directstay?schema=public
# Prisma migrations / direct admin connection
DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/directstay?schema=public
